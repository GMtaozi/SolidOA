<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.solidoa.attendance.mapper.RepairCardMapper">

    <select id="selectPendingList" resultType="com.solidoa.attendance.entity.RepairCard">
        SELECT * FROM oa_repair_card
        WHERE status = 'PENDING'
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

</mapper>