<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.solidoa.workflow.mapper.ApprovalNodeDetailMapper">

    <resultMap id="BaseResultMap" type="com.solidoa.workflow.entity.ApprovalNodeDetail">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="node_order" property="nodeOrder"/>
        <result column="node_name" property="nodeName"/>
        <result column="approver_id" property="approverId"/>
        <result column="approver_name" property="approverName"/>
        <result column="node_status" property="nodeStatus"/>
        <result column="approve_type" property="approveType"/>
        <result column="comment" property="comment"/>
        <result column="action_time" property="actionTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="VOResultMap" type="com.solidoa.workflow.vo.ApprovalNodeDetailVO">
        <id column="id" property="id"/>
        <result column="node_order" property="nodeOrder"/>
        <result column="node_name" property="nodeName"/>
        <result column="approver_id" property="approverId"/>
        <result column="approver_name" property="approverName"/>
        <result column="node_status" property="nodeStatus"/>
        <result column="approve_type" property="approveType"/>
        <result column="comment" property="comment"/>
        <result column="action_time" property="actionTime"/>
    </resultMap>

    <!-- 根据记录ID查询节点列表 -->
    <select id="selectByRecordId" resultMap="BaseResultMap">
        SELECT * FROM oa_approval_node_detail
        WHERE record_id = #{recordId}
        ORDER BY node_order ASC
    </select>

    <!-- 根据记录ID查询节点详情VO列表 -->
    <select id="selectVOByRecordId" resultMap="VOResultMap">
        SELECT id, node_order, node_name, approver_id, approver_name,
               node_status, approve_type, comment, action_time
        FROM oa_approval_node_detail
        WHERE record_id = #{recordId}
        ORDER BY node_order ASC
    </select>

    <!-- 查询用户审批过的记录ID列表 -->
    <select id="selectApprovedRecordIdsByUser" resultType="java.lang.Long">
        SELECT DISTINCT record_id FROM oa_approval_node_detail
        WHERE approver_id = #{userId}
    </select>

</mapper>