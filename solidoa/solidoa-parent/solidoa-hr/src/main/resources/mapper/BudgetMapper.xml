<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.solidoa.hr.finance.mapper.BudgetMapper">

    <select id="selectByDeptAndMonth" resultType="com.solidoa.hr.finance.entity.Budget">
        SELECT * FROM oa_budget
        WHERE dept_id = #{deptId} AND year = #{year} AND month = #{month}
        LIMIT 1
    </select>

    <select id="selectByIdForUpdate" resultType="com.solidoa.hr.finance.entity.Budget">
        SELECT * FROM oa_budget WHERE id = #{id} FOR UPDATE
    </select>

</mapper>